pkgname=bootc
pkgver=1.14.1
pkgrel=1
pkgdesc="Bootable container system"
arch=('x86_64' 'aarch64')
url="https://github.com/containers/bootc"
license=('Apache-2.0' 'MIT')
depends=('composefs' 'ostree' 'skopeo' 'podman')
makedepends=('make' 'openssl' 'systemd' 'cargo' 'go-md2man')
source=("bootc-${pkgver}.tar.zstd::${url}/releases/download/v${pkgver}/bootc-${pkgver}.tar.zstd"
  "bootc-${pkgver}-vendor.tar.zstd::${url}/releases/download/v${pkgver}/bootc-${pkgver}-vendor.tar.zstd")
sha256sums=('SKIP' 'SKIP')

prepare() {
  cd "${pkgname}-${pkgver}"
  cp -R ../vendor vendor
  cp .cargo/vendor-config.toml .cargo/config.toml
}

build() {
  cd "${pkgname}-${pkgver}"
  cargo build --release --frozen --bins
  make manpages
}

package() {
  cd "${pkgname}-${pkgver}"
  make install DESTDIR="$pkgdir"
}
